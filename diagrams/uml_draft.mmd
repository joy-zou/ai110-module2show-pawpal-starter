classDiagram
    class Owner {
        +name: str
        +availability_minutes: int
        +preferences: list[str]
        +add_pet(pet: Pet)
        +update_preferences(preferences: list[str])
    }

    class Pet {
        +name: str
        +species: str
        +age: int
        +energy_level: str
        +health_notes: list[str]
        +add_task(task: Task)
        +get_task_count() int
    }

    class Task {
        +title: str
        +description: str
        +duration_minutes: int
        +priority: str
        +time_window: str
        +is_recurring: bool
        +is_completed: bool
        +mark_complete()
        +update_details(title: str, duration: int, priority: str)
    }

    class Schedule {
        +date: date
        +owner: Owner
        +pet: Pet
        +planned_tasks: list[Task]
        +total_duration_minutes: int
        +generate_plan(tasks: list[Task], owner: Owner, pet: Pet)
        +explain_plan() str
        +display_plan() str
    }

    Owner "1" *-- "1..*" Pet : owns
    Pet "1" *-- "0..*" Task : needs
    Schedule "1" --> "1" Owner : for
    Schedule "1" --> "1" Pet : for
    Schedule "1" --> "0..*" Task : includes
